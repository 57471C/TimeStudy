{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "TimeStudy",
  "version": "0.1.0",
  "identifier": "com.timestudy.desktop",
  "build": {
    "devUrl": null,
    "frontendDist": "../ui",
    "beforeDevCommand": "npm run build:css",
    "beforeBuildCommand": "npm run build:css"
  },
  "app": {
    "windows": [
      {
        "title": "TimeStudy - v0.4.5",
        "width": 1028,
        "height": 786,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
      "enable": true,
      "scope": ["**"]
    }
  }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
