{
  "name": "timestudy",
  "version": "0.5.3",
  "description": "A web-based application for conducting time and motion studies.",
  "main": "ui/index.html",
  "scripts": {
    "start": "tauri dev",
    "build:exe": "tauri build",
    "build:css": "tailwindcss -i ./ui/input.css -o ./ui/tailwind.css --minify",
    "watch:css": "tailwindcss -i ./ui/input.css -o ./ui/tailwind.css --watch",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write ."
  },
  "keywords": [
    "timestudy",
    "time-motion",
    "manufacturing",
    "process-analysis"
  ],
  "author": "Terry Minett",
  "license": "MIT",
  "devDependencies": {
    "@biomejs/biome": "2.4.15",
    "@tailwindcss/cli": "^4.3.0",
    "@tauri-apps/cli": "^2.0.0",
    "husky": "^9.1.6",
    "lint-staged": "^15.2.10",
    "tailwindcss": "^4.3.0"
  },
  "lint-staged": {
    "**/*.{js,json,css,html,md}": [
      "biome check --write --no-errors-on-unmatched --files-ignore-unknown=true"
    ]
  },
  "dependencies": {
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-fs": "^2.5.1",
    "@tauri-apps/plugin-shell": "^2.0.0"
  }
}
