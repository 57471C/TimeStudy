{
  "name": "timestudy",
  "version": "0.4.5",
  "description": "A web-based application for conducting time and motion studies.",
  "main": "index.html",
  "scripts": {
    "build:css": "tailwindcss -i ./input.css -o ./tailwind.css --minify",
    "watch:css": "tailwindcss -i ./input.css -o ./tailwind.css --watch",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write ."
  },
  "keywords": [
    "timestudy",
    "time-motion",
    "manufacturing",
    "process-analysis"
  ],
  "author": "Terry Minett",
  "license": "MIT",
  "devDependencies": {
    "@biomejs/biome": "2.4.15",
    "@tailwindcss/cli": "^4.3.0",
    "husky": "^9.1.6",
    "lint-staged": "^15.2.10",
    "tailwindcss": "^4.3.0"
  },
  "lint-staged": {
    "**/*.{js,json,css,html,md}": [
      "biome check --write"
    ]
  }
}
