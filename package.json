{
  "name": "timestudy",
  "version": "0.3.2",
  "description": "A web-based application for conducting time and motion studies.",
  "main": "index.html",
  "scripts": {
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write ."
  },
  "keywords": ["timestudy", "time-motion", "manufacturing", "process-analysis"],
  "author": "Terry Minett",
  "license": "MIT",
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "husky": "^9.1.6",
    "lint-staged": "^15.2.10"
  },
  "lint-staged": {
    "**/*.{js,json,css,html,md}": [
      "biome check --write"
    ]
  }
}